# Copy to .env.local and fill in the values below.

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Mapbox access token — sign up (free tier) at https://account.mapbox.com/
# and create a token. Used for the My Fields map + polygon drawing
# (mapbox-gl + mapbox-gl-draw). See GAPS.md Gap 2.
NEXT_PUBLIC_MAP_TILES_KEY=
