# Copy to .env and fill in the values below. Never commit .env (see .gitignore).

# ------------------------------------------------------------------
# General app
# ------------------------------------------------------------------
APP_NAME=Precision Agriculture Platform
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Public base URL of this backend — used to build absolute links to
# generated static assets (NDVI/NDMI PNGs, scan photos) in API responses.
APP_BASE_URL=http://localhost:8000

# Comma-separated frontend origin(s) allowed by CORS.
CORS_ORIGINS=http://localhost:3000

# Public base URL of the frontend — used to build password-reset links.
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# ------------------------------------------------------------------
# Local Homebrew Postgres with trust auth (no password) looks like:
#   postgresql://<os-user>@localhost:5432/jadeed_kashtkar_db
# Docker Compose sets this automatically — see docker-compose.yml.
DATABASE_URL=postgresql://user:password@localhost:5432/jadeed_kashtkar_db

# ------------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------------
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------------
# Copernicus Data Space Ecosystem (CDSE) — OAuth2 client credentials
# ------------------------------------------------------------------
# Sign up (free) at https://dataspace.copernicus.eu/ , then create an
# OAuth client under your account dashboard -> "OAuth clients". Used for
# the NDVI/NDMI Sentinel-2 pipeline (openEO). See GAPS.md Gap 3.
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=
CDSE_OPENEO_URL=openeo.dataspace.copernicus.eu

# ------------------------------------------------------------------
# NDVI / Sentinel-2 processing defaults
# ------------------------------------------------------------------
SENTINEL2_COLLECTION=SENTINEL2_L2A
MAX_CLOUD_COVER_PERCENT=20.0
NDVI_SEARCH_WINDOW_DAYS=30

# ------------------------------------------------------------------
# Weather (Open-Meteo — free, keyless) & alert engine
# ------------------------------------------------------------------
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
WEATHER_CACHE_TTL_SECONDS=3600
ALERT_SWEEP_INTERVAL_HOURS=1

# ------------------------------------------------------------------
# Disease scanner
# ------------------------------------------------------------------
# "demo" is the only implementation right now — a deterministic fake
# classifier behind InferenceProvider. See GAPS.md Gap 5.
INFERENCE_PROVIDER=demo
SCAN_IMAGES_DIR=static/scan_images

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------
LOG_LEVEL=INFO
